{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "server.js",
        "public/**",
        "*.html",
        "*.css",
        "*.js"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/stats/public", "destination": "/api/index" },
    { "source": "/signup", "destination": "/api/index" },
    { "source": "/login", "destination": "/api/index" },
    { "source": "/forgot-password", "destination": "/api/index" },
    { "source": "/reset-password", "destination": "/api/index" },
    { "source": "/auth/(.*)", "destination": "/api/index" },
    { "source": "/profile", "destination": "/api/index" },
    { "source": "/add-loan", "destination": "/api/index" },
    { "source": "/loans", "destination": "/api/index" },
    { "source": "/loans/(.*)", "destination": "/api/index" },
    { "source": "/payments", "destination": "/api/index" },
    { "source": "/payments/(.*)", "destination": "/api/index" },
    { "source": "/queries", "destination": "/api/index" },
    { "source": "/queries/(.*)", "destination": "/api/index" },
    { "source": "/admin/(.*)", "destination": "/api/index" }
  ]
}
