# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/loanReminder

# JWT Secret (Change in production!)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Admin Secret (Change in production!)
ADMIN_SECRET_KEY=your_admin_secret_key_here_change_in_production

# M-Pesa Daraja API (Get from https://developer.safaricom.co.ke/)
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
