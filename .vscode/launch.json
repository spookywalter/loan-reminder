{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend Dev",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "nodemon",
            "program": "${workspaceFolder}/server.js",
            "restart": true,
            "env": {
                "PORT": "5000"
            },
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Frontend (serve-frontend)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/serve-frontend.js",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Frontend served on http://localhost:5500"
            }
        },
        {
            "name": "Attach Backend",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "skipFiles": ["<node_internals>/**"]
        }
    ],
    "compounds": [
        {
            "name": "Full Stack",
            "configurations": ["Backend Dev", "Frontend (serve-frontend)"],
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Frontend served on http://localhost:5500",
                "uriFormat": "http://localhost:5500"
            }
        }
    ]
}
